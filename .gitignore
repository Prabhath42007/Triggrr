# ============================================================
# .gitignore — Files that must never go to GitHub
# ============================================================

# ─── Environment variables ──────────────────────────────────
# .env contains your real API keys and URLs. NEVER commit it.
# .env.example (the template with no real values) is safe to commit.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local


# ─── Dependencies ───────────────────────────────────────────
# Installed by npm install — regenerated from package.json
node_modules/


# ─── Build output ───────────────────────────────────────────
# Generated by npm run build — Vercel builds this on the server
dist/
dist-ssr/
build/


# ─── Vite cache ─────────────────────────────────────────────
.vite/
*.local


# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
!.vscode/extensions.json   # keep recommended extensions
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.sw?


# ─── macOS ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride


# ─── Windows ────────────────────────────────────────────────
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/


# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# ─── Testing (Batch 2) ──────────────────────────────────────
coverage/
.nyc_output


# ─── Misc ───────────────────────────────────────────────────
*.pem
*.key
.cache/
tmp/
temp/
